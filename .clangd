# Use the compile_commands.json generated by PlatformIO via ESPHome.
# After running `esphome compile devices/<your-device>.yaml` once, update the
# device name below if needed (or symlink it to a stable path).
CompileFlags:
  CompilationDatabase: .esphome/build/ge-dishwasher/.pioenvs/ge-dishwasher
  Add:
    - -Wno-unknown-warning-option
    - -Wno-unknown-pragmas
    - -ferror-limit=0
  Remove:
    # PlatformIO emits some flags clangd's bundled clang doesn't understand.
    - -mtarget-align
    - -mlongcalls
    - -fstrict-volatile-bitfields
    - -free
    - -fipa-pta
    - -mtext-section-literals
    - -fno-tree-switch-conversion

Diagnostics:
  Suppress:
    # Arduino.h on ESP8266 #defines RISING/FALLING which clashes harmlessly
    # with our enum members (handled at the call site by the C++ build).
    - macro_redefined
